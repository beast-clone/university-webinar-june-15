# Country pathway routing.
# Each rule proxies a path to its own independent Netlify site so the country
# repos can update without touching this hub. Status 200 = transparent rewrite
# (URL bar stays at goocampusevents.com). `!` = force, overrides any local file.

/amc-pathway/*  https://goocampus-amc-pathway.netlify.app/amc-pathway/:splat  200!
/nz-pathway/*   https://goocampus-nz-pathway.netlify.app/nz-pathway/:splat    200!
/gc-dashboard/* https://goocampus-dashboard.netlify.app/gc-dashboard/:splat   200!

# GC Consulting — Medical PG Abroad 1:1 session (hosted on GitHub Pages).
/gc-consulting/*  https://beast-clone.github.io/10k-membership-landing/:splat  200!
/gc-consulting    https://beast-clone.github.io/10k-membership-landing/        200!
